{
  "agentName": "Text Summarizer Pro",
  "version": "1.0.0",
  "capabilities": [
    {
      "name": "summarize_text",
      "description": "Summarize long text into concise bullet points",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The text to summarize"
          },
          "maxBullets": {
            "type": "number",
            "description": "Maximum number of bullet points (default: 5)"
          }
        },
        "required": ["text"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Summarized text in bullet points"
          },
          "wordCount": {
            "type": "number",
            "description": "Original word count"
          }
        }
      },
      "baseCost": 25.0,
      "estimatedDurationSeconds": 10,
      "slaGuaranteeSeconds": 30
    }
  ],
  "sandboxLevel": "isolated",
  "verificationMode": "automated",
  "maxConcurrentTasks": 5,
  "minReputationRequired": 0.0,
  "acceptsDisputes": true
}
