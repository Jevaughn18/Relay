# Relay Protocol Environment Variables

# Agent Configuration
AGENT_ID=my_agent_id
AGENT_NAME=MyAgent

# Network Configuration (for future use)
# RELAY_NETWORK_URL=https://relay.example.com
# RELAY_NETWORK_API_KEY=your_api_key

# Storage
RELAY_DATA_DIR=~/.relay

# Logging
LOG_LEVEL=info

# Development
NODE_ENV=development
