{
  "name": "relay-protocol",
  "version": "0.1.0",
  "description": "Gateway for AI agents to communicate - connect any agent (OpenClaw, ChatGPT, WhatsApp, etc.) to delegate tasks",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/src/crypto/index.js",
      "require": "./dist/src/crypto/index.js",
      "types": "./dist/src/crypto/index.d.ts"
    },
    "./ai": {
      "import": "./dist/src/ai/index.js",
      "require": "./dist/src/ai/index.js",
      "types": "./dist/src/ai/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jevaughn18/Relay.git"
  },
  "homepage": "https://github.com/Jevaughn18/Relay#readme",
  "bugs": {
    "url": "https://github.com/Jevaughn18/Relay/issues"
  },
  "bin": {
    "relay": "dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:all": "tsc && npm run dashboard:build",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js || true",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/src/cli/index.js",
    "example:local": "node dist/examples/local-shared-credits.js",
    "local": "tsx src/scripts/start-local-stack.ts",
    "stack:start": "tsx src/scripts/start-local-stack.ts",
    "dashboard:dev": "vite src/dashboard/ui",
    "dashboard:build": "vite build src/dashboard/ui --outDir ../../../dist/dashboard",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "escrow",
    "delegation",
    "protocol",
    "contracts"
  ],
  "author": "Relay Team",
  "license": "MIT",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@copilotkit/react-core": "^1.51.4",
    "@copilotkit/react-ui": "^1.51.4",
    "@copilotkit/runtime": "^1.51.4",
    "@types/express": "^5.0.6",
    "ajv": "^8.12.0",
    "axios": "^1.6.5",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "date-fns": "^3.2.0",
    "dotenv": "^16.4.1",
    "express": "^5.2.1",
    "inquirer": "^13.3.0",
    "multicast-dns": "^7.2.5",
    "ora": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/jest": "^29.5.11",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
