{
  "name": "relay-protocol",
  "version": "0.1.0",
  "description": "Decentralized task escrow protocol for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "relay": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js || true",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/src/cli/index.js",
    "example:local": "node dist/examples/local-shared-credits.js",
    "stack:start": "tsx src/scripts/start-local-stack.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "escrow",
    "delegation",
    "protocol",
    "contracts"
  ],
  "author": "Relay Team",
  "license": "MIT",
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@types/express": "^5.0.6",
    "ajv": "^8.12.0",
    "axios": "^1.6.5",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "date-fns": "^3.2.0",
    "dotenv": "^16.4.1",
    "express": "^5.2.1",
    "inquirer": "^13.3.0",
    "ora": "^8.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
